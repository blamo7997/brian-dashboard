<Window x:Class="LumenPrimeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lumen Prime Ecosystem" Width="1420" Height="900" WindowStartupLocation="CenterScreen" Background="{StaticResource LumenBg}">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border CornerRadius="24" Padding="18" BorderBrush="#D8AA4B" BorderThickness="1.4">
            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#090603" Offset="0"/><GradientStop Color="#4A2C08" Offset="0.55"/><GradientStop Color="#0B0703" Offset="1"/></LinearGradientBrush></Border.Background>
            <DockPanel>
                <StackPanel DockPanel.Dock="Left"><TextBlock Text="Brian Workspace" FontSize="32" FontWeight="Bold" Foreground="#FFE6A3"/><TextBlock Text="Lumen Prime Ecosystem — Universal Ledger, OpenAI Command Bridge, Sovereign Security, Localization, Voice, Resource Concierge" FontSize="13" Foreground="#EEDFBF"/></StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="BtnSecurityScan" Content="Run Security Scan"/><Button x:Name="BtnOpenFolder" Content="Open Lumen Folder"/><Button x:Name="BtnReadAloud" Content="OpenAI Read Aloud"/></StackPanel>
            </DockPanel>
        </Border>
        <Border Grid.Row="1" Margin="0,14,0,14" CornerRadius="22" Padding="14" BorderBrush="#D8AA4B" BorderThickness="1">
            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#120D08" Offset="0"/><GradientStop Color="#2D1C07" Offset="1"/></LinearGradientBrush></Border.Background>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox x:Name="CommandBox" MinHeight="54" FontSize="15" TextWrapping="Wrap" AcceptsReturn="True" Padding="12" Text="Tell Lumen exactly what you want. Lumen will preserve protected files, save to Vault, use OpenAI, analyze intent, and return Green / Yellow / Red options."/>
                <Button Grid.Column="1" x:Name="BtnSendOpenAI" Content="Send to OpenAI Bridge" MinWidth="170"/><Button Grid.Column="2" x:Name="BtnSaveVault" Content="Save to Vault" MinWidth="120"/><Button Grid.Column="3" x:Name="BtnClear" Content="Clear" MinWidth="80"/>
            </Grid>
        </Border>
        <TabControl Grid.Row="2" Background="Transparent" BorderBrush="#C99A3D">
            <TabItem Header="Dashboard"><ScrollViewer><WrapPanel Margin="10" x:Name="DashboardPanel"/></ScrollViewer></TabItem>
            <TabItem Header="Command Bridge"><Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBox x:Name="ResponseBox" FontSize="14" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="14"/><StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="BtnGreen" Content="✅ Green Implement"/><Button x:Name="BtnYellow" Content="🟡 Yellow Revise"/><Button x:Name="BtnRed" Content="❌ Red Redesign"/></StackPanel></Grid></TabItem>
            <TabItem Header="Universal Activity Ledger"><Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><TextBlock Text="Search ledger:" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox x:Name="LedgerSearch" Width="360" Padding="8"/><Button x:Name="BtnSearchLedger" Content="Search"/><Button x:Name="BtnRefreshLedger" Content="Refresh"/></StackPanel><TextBox Grid.Row="1" x:Name="LedgerBox" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="12"/></Grid></TabItem>
            <TabItem Header="Vault"><TextBox x:Name="VaultBox" Margin="10" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="12"/></TabItem>
            <TabItem Header="Sovereign Security"><TextBox x:Name="SecurityBox" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14"/></TabItem>
            <TabItem Header="Communications"><TextBox x:Name="CommunicationsBox" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14"/></TabItem>
            <TabItem Header="Localization Intelligence"><TextBox x:Name="LocalizationBox" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14"/></TabItem>
            <TabItem Header="Accessibility & Care"><TextBox x:Name="AccessibilityBox" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14"/></TabItem>
            <TabItem Header="Resource Concierge"><Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Button x:Name="BtnOpenDotNet" Content=".NET"/><Button x:Name="BtnOpenOpenAI" Content="OpenAI"/><Button x:Name="BtnOpenCloudflare" Content="Cloudflare"/><Button x:Name="BtnOpenSupabase" Content="Supabase"/><Button x:Name="BtnOpenGitHub" Content="GitHub"/><Button x:Name="BtnOpenOWASP" Content="OWASP"/><Button x:Name="BtnOpenCIS" Content="CIS"/></StackPanel><TextBox Grid.Row="1" x:Name="ResourceBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14"/></Grid></TabItem>
            <TabItem Header="Implementation Registry"><TextBox x:Name="RegistryBox" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14"/></TabItem>
        </TabControl>
        <Border Grid.Row="3" CornerRadius="14" Padding="10" BorderBrush="#D8AA4B" BorderThickness="1" Background="#100B06"><TextBlock x:Name="StatusText" Text="Ready. Lumen preserves Vault / Config / Secrets / Reports / Backups and logs every action with timestamp, category, user, and result." Foreground="#FFE6A3"/></Border>
    </Grid>
</Window>

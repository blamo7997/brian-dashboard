<script>
(function () {

  const toggle = document.getElementById('brianco-chat-toggle');
  const panel = document.getElementById('brianco-chat-panel');
  const form = document.getElementById('brianco-chat-form');
  const input = document.getElementById('brianco-chat-input');
  const log = document.getElementById('brianco-chat-log');

  const endpoint =
    'https://brianco-backend-clean.vercel.app/api/chat';

  toggle.addEventListener('click', function () {
    panel.hidden = !panel.hidden;
  });

  function addMessage(text, mine) {

    const div = document.createElement('div');

    div.style.marginBottom = '12px';
    div.style.padding = '16px 18px';
    div.style.borderRadius = '18px';

    div.style.background = mine
      ? 'rgba(215,185,142,.18)'
      : 'rgba(255,255,255,.06)';

    div.style.lineHeight = '1.7';
    div.textContent = text;

    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
  }

  form.addEventListener('submit', async function (e) {

    e.preventDefault();

    const message = input.value.trim();

    if (!message) return;

    input.value = '';

    addMessage(message, true);

    addMessage(
      'One moment — I am preparing a more considered recommendation for you.',
      false
    );

    try {

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          message: message
        })
      });

      const data = await response.json();

      log.lastChild.remove();

      addMessage(
        data.reply || 'I am here to assist.',
        false
      );

    } catch (err) {

      log.lastChild.remove();

      addMessage(
        'The concierge is briefly unavailable. Please return in a moment, and I will be glad to assist.',
        false
      );
    }
  });

})();
</script>

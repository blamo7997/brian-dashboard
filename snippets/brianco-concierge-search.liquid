<div id="brianco-concierge-search" class="bc-concierge-search">
  <p class="bc-eyebrow">Brian & Co Concierge Intelligence</p>
  <h2>Tell us what would be most helpful today.</h2>
  <p>
    Describe what you are seeking, and Brian & Co will suggest appropriate curated offerings,
    digital products, memberships, accessibility support, role pathways, or concierge guidance.
  </p>

  <textarea id="bc-search-input" placeholder="Examples: Help me prepare my family for emergencies. I need business recommendations. I would appreciate larger text. Please communicate in Spanish. Show me premium concierge options."></textarea>

  <button type="button" id="bc-search-button">Request Thoughtful Suggestions</button>

  <div id="bc-search-results" class="bc-search-results">
    Awaiting your request.
  </div>
</div>

<style>
.bc-concierge-search{
  max-width:1180px;margin:28px auto;padding:28px;border-radius:30px;
  background:linear-gradient(135deg,rgba(5,5,5,.94),rgba(33,25,12,.94));
  color:#fff7df;border:1px solid rgba(242,201,92,.50);
  box-shadow:0 30px 110px rgba(0,0,0,.35);font-family:Georgia,serif;
}
.bc-concierge-search .bc-eyebrow{letter-spacing:.22em;text-transform:uppercase;font-size:12px;color:#f2c95c}
.bc-concierge-search h2{font-size:clamp(30px,5vw,56px);line-height:1.05;margin:10px 0 14px}
.bc-concierge-search p{line-height:1.7;color:rgba(255,247,223,.86)}
#bc-search-input{
  width:100%;min-height:120px;margin-top:16px;padding:16px;border-radius:18px;
  background:#090807;color:#fff7df;border:1px solid rgba(242,201,92,.42);
  font:inherit;
}
#bc-search-button{
  margin-top:14px;border:1px solid rgba(242,201,92,.62);border-radius:999px;
  padding:13px 18px;background:linear-gradient(135deg,#1c160e,#6d5422);
  color:#fff7df;cursor:pointer;font:inherit;
}
.bc-search-results{
  margin-top:18px;padding:18px;border-radius:20px;background:rgba(0,0,0,.42);
  border:1px solid rgba(242,201,92,.32);white-space:pre-wrap;line-height:1.65;
}
</style>

<script>
(function(){
  var input=document.getElementById("bc-search-input");
  var button=document.getElementById("bc-search-button");
  var results=document.getElementById("bc-search-results");
  if(!input||!button||!results) return;

  var suggestions = [
    {keys:["emergency","prepare","preparedness","family","storm","disaster"], title:"Preparedness AI+ Guidance", text:"A refined preparedness pathway for individuals and families seeking clearer planning, safer routines, and practical next steps."},
    {keys:["business","company","professional","organization","work"], title:"Business Intelligence AI+™", text:"Professional support for planning, positioning, operational clarity, and decision-ready business guidance."},
    {keys:["concierge","premium","executive","private"], title:"Executive Concierge™", text:"A more elevated concierge pathway for users seeking personalized, high-touch assistance and refined recommendations."},
    {keys:["accessibility","large text","dyslexia","elderly","parent","reduced motion","screen reader"], title:"Accessibility & Personal Comfort", text:"A personalized experience pathway that adapts language, reading comfort, text size, motion, and guidance preferences where supported."},
    {keys:["language","spanish","french","arabic","translate","dialect"], title:"Preferred Language, Dialect & Communication Style", text:"A natural-language communication preference experience that lets users describe how Brian & Co should communicate with them."},
    {keys:["digital","download","template","product","tool"], title:"Digital Product Guidance", text:"Approval-ready digital products and guided resources prepared in Brian & Co’s refined tone."},
    {keys:["lawyer","legal","investor","banker","artisan","creator","influencer","supplier"], title:"Professional Relationship Pathway", text:"Role-specific pathways for professional, creative, financial, legal, supplier, and collaborative relationships."}
  ];

  function suggest(text){
    var q=(text||"").toLowerCase();
    var found=suggestions.filter(function(s){
      return s.keys.some(function(k){return q.indexOf(k)>-1});
    });

    if(!found.length){
      found=[
        {title:"Personalized Concierge Guidance", text:"Brian & Co can help refine your request and suggest appropriate offerings, access pathways, or resources based on what matters most to you."},
        {title:"Curated Offerings", text:"Tell us whether you are shopping, preparing, building a business, seeking accessibility support, or requesting a professional pathway."}
      ];
    }

    return found.map(function(s){
      return "• " + s.title + "\n  " + s.text;
    }).join("\n\n");
  }

  button.addEventListener("click",function(){
    var text=input.value.trim();
    if(!text){
      results.textContent="Please share what would be most helpful, meaningful, or important to you today.";
      return;
    }
    localStorage.setItem("brianco_last_concierge_search", text);
    results.textContent="Thoughtful suggestions prepared for your request:\n\n" + suggest(text);
  });

  var saved=localStorage.getItem("brianco_last_concierge_search");
  if(saved){ input.value=saved; }
})();
</script>

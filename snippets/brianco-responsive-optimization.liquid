<style>

:root{
  --brianco-radius:24px;
  --brianco-gap:18px;
  --brianco-max:1600px;
}

html{
  scroll-behavior:smooth;
  -webkit-text-size-adjust:100%;
}

body{
  overflow-x:hidden;
}

img{
  max-width:100%;
  height:auto;
}

.brianco-responsive-wrap{
  width:min(100%, var(--brianco-max));
  margin-inline:auto;
  padding-inline:clamp(14px,2vw,34px);
}

#brianco-chatbot,
.brianco-chatbot,
[data-brianco-chatbot]{

  position:fixed !important;
  right:18px !important;
  bottom:18px !important;
  z-index:999999 !important;

  width:min(420px, calc(100vw - 22px)) !important;
  max-height:min(82vh, 900px) !important;

  border-radius:26px !important;

  overflow:hidden !important;

  box-shadow:
    0 10px 40px rgba(0,0,0,.16),
    0 3px 12px rgba(0,0,0,.08) !important;

  backdrop-filter:blur(12px);
}

#brianco-chatbot *,
.brianco-chatbot *,
[data-brianco-chatbot] *{
  max-width:100%;
}

#brianco-dynamic-faq,
#brianco-live-faq{

  width:min(100%, 1500px);
  margin:48px auto;
  padding:clamp(18px,2vw,34px);

  border-radius:28px;

  overflow:hidden;
}

#brianco-dynamic-faq h2,
#brianco-live-faq h2{

  font-size:clamp(28px,3vw,48px);
  line-height:1.1;
}

#brianco-dynamic-faq p,
#brianco-live-faq p{

  font-size:clamp(14px,1vw,18px);
  line-height:1.7;
}

button,
.button,
.btn,
input,
textarea,
select{

  min-height:48px;
  font-size:max(16px,1rem);
}

textarea{
  resize:vertical;
}

table{
  display:block;
  overflow-x:auto;
  width:100%;
}

.collection-grid,
.product-grid,
.grid{

  display:grid;
  gap:clamp(12px,1.6vw,28px);
}

.product-card,
.card,
.collection-card{

  border-radius:24px;
  overflow:hidden;
}

.product-card img,
.card img,
.collection-card img{

  width:100%;
  height:auto;
  object-fit:cover;
}

footer{

  overflow:hidden;
}

@media (max-width: 1200px){

  .collection-grid,
  .product-grid,
  .grid{

    grid-template-columns:repeat(3,minmax(0,1fr));
  }

}

@media (max-width: 980px){

  .collection-grid,
  .product-grid,
  .grid{

    grid-template-columns:repeat(2,minmax(0,1fr));
  }

  #brianco-chatbot,
  .brianco-chatbot,
  [data-brianco-chatbot]{

    width:min(100vw - 12px, 520px) !important;

    right:6px !important;
    bottom:6px !important;
  }

}

@media (max-width: 768px){

  body{
    font-size:16px;
  }

  header,
  footer{
    padding-inline:12px;
  }

  .collection-grid,
  .product-grid,
  .grid{

    grid-template-columns:1fr;
  }

  #brianco-chatbot,
  .brianco-chatbot,
  [data-brianco-chatbot]{

    width:calc(100vw - 10px) !important;
    height:min(88vh,900px) !important;

    right:5px !important;
    bottom:5px !important;

    border-radius:22px !important;
  }

  #brianco-dynamic-faq,
  #brianco-live-faq{

    margin:24px auto;
    padding:18px;
  }

}

@media (max-width: 480px){

  body{
    overflow-x:hidden;
  }

  h1{
    font-size:clamp(30px,8vw,48px);
  }

  h2{
    font-size:clamp(24px,7vw,38px);
  }

  h3{
    font-size:clamp(20px,5vw,28px);
  }

  p,
  li,
  a,
  button,
  input,
  textarea{
    font-size:16px !important;
  }

  #brianco-chatbot,
  .brianco-chatbot,
  [data-brianco-chatbot]{

    border-radius:18px !important;
  }

}

</style>

<script defer>
(function(){

if(window.__BRIANCO_RESPONSIVE_LAYER__) return;
window.__BRIANCO_RESPONSIVE_LAYER__ = true;

window.BrianCoResponsive = {

  update(){

    document.querySelectorAll("img").forEach((img)=>{

      if(!img.getAttribute("loading")){
        img.setAttribute("loading","lazy");
      }

      if(!img.getAttribute("decoding")){
        img.setAttribute("decoding","async");
      }

      if(!img.getAttribute("width")){
        img.setAttribute("width","1200");
      }

      if(!img.getAttribute("height")){
        img.setAttribute("height","1200");
      }

    });

    document.querySelectorAll("iframe").forEach((frame)=>{

      frame.style.maxWidth = "100%";

    });

  }

};

document.addEventListener("DOMContentLoaded", function(){

  window.BrianCoResponsive.update();

});

setInterval(function(){

  window.BrianCoResponsive.update();

}, 4000);

const observer = new MutationObserver(function(){

  window.BrianCoResponsive.update();

});

observer.observe(document.documentElement,{
  childList:true,
  subtree:true
});

console.log("Brian & Co responsive optimization active.");

})();
</script>
<section class="brianco-localized-adaptive-shell"
  data-bc-localized="true"
  data-bc-dynamic-logo="approval-gated"
  data-bc-dynamic-favicon="approval-gated">
  <div class="bc-localized-inner">
    <p class="eyebrow" data-i18n="eyebrow">Brian & Co Adaptive Concierge</p>
    <h2 data-i18n="headline">A refined experience shaped around your language, role, accessibility needs, and local context.</h2>
    <p data-i18n="body">
      Brian & Co prepares localized, accessibility-aware, role-aware shopping and digital product guidance.
      Legal, payment, theme-publishing, and public-pricing changes remain founder-approved.
    </p>
    <div class="bc-localized-grid">
      <article><h3>Native Language</h3><p>Text adapts to preferred language where supported.</p></article>
      <article><h3>Local Tone</h3><p>Marketing copy is prepared for regional/local expectations.</p></article>
      <article><h3>Role-Aware UX</h3><p>Customers, creators, suppliers, investors, lawyers, and admins see appropriate paths.</p></article>
      <article><h3>Adaptive Identity</h3><p>Logo/favicon personalization is scaffolded and approval-gated.</p></article>
    </div>
  </div>
</section>


<section class="bc-Your Place Within Brian & Co-page">
  <div class="bc-Your Place Within Brian & Co-card">
    <p class="bc-eyebrow">Your Private Brian & Co Presence</p>
    <h1>Create your Your Place Within Brian & Co.</h1>
    <p class="bc-lead">
      Create a Your Private Brian & Co Presence to request role access, complimentary access where appropriate,
      digital-product access, concierge help, and founder-reviewed pathways without leaving the website experience.
    </p>

    {% form 'create_customer', class: 'bc-form' %}
      {{ form.errors | default_errors }}

      <label>First name</label>
      <input type="text" name="customer[first_name]" autocomplete="given-name">

      <label>Last name</label>
      <input type="text" name="customer[last_name]" autocomplete="family-name">

      <label>Email</label>
      <input type="email" name="customer[email]" autocomplete="email" required>

      <label>Password</label>
      <input type="password" name="customer[password]" autocomplete="new-password" required>

      <button type="Share With Brian & Co">Begin Your Brian & Co Experience</button>
    {% endform %}

    <div class="bc-native-note">
      After your Your Place Within Brian & Co is created, return to your Your Place Within Brian & Co page to request role access, family/girlfriend complimentary access,
      or digital-product access for Brian’s green-check review.
    </div>

    <div class="bc-Your Place Within Brian & Co-links">
      <a href="{{ routes.Your Place Within Brian & Co_Your Place Within Brian & Co_url }}">Already have an Your Place Within Brian & Co?</a>
      <a href="{{ routes.root_url }}">Return to Brian & Co</a>
    </div>
  </div>
</section>

<style>
  .bc-Your Place Within Brian & Co-page{min-height:72vh;padding:clamp(34px,6vw,86px) 18px;background:radial-gradient(circle at top left,#fff3df,#fff 42%,#f4eadf)}
  .bc-Your Place Within Brian & Co-card{max-width:820px;margin:0 auto;border:1px solid rgba(31,26,23,.13);border-radius:34px;padding:clamp(26px,5vw,52px);background:rgba(255,255,255,.78);box-shadow:0 28px 90px rgba(31,26,23,.10)}
  .bc-eyebrow{letter-spacing:.18em;text-transform:uppercase;font-size:12px;opacity:.72}
  .bc-Your Place Within Brian & Co-card h1{font-size:clamp(38px,6vw,64px);line-height:1.02;margin:10px 0 16px}
  .bc-lead{font-size:18px;line-height:1.7}
  .bc-form{display:grid;gap:12px;margin-top:24px}
  .bc-form label{font-size:14px;letter-spacing:.04em}
  .bc-form input{width:100%;padding:14px 15px;border-radius:14px;border:1px solid rgba(31,26,23,.17);font:inherit;background:#fff}
  .bc-form button{justify-self:start;border:0;border-radius:999px;padding:13px 20px;background:#1f1a17;color:#fff;cursor:pointer;font:inherit}
  .bc-native-note{margin-top:20px;padding:16px;border-radius:18px;background:#fff;border:1px solid rgba(31,26,23,.12);line-height:1.65}
  .bc-Your Place Within Brian & Co-links{display:flex;gap:12px;flex-wrap:wrap;margin-top:22px}
  .bc-Your Place Within Brian & Co-links a{color:inherit;text-decoration:none;border:1px solid rgba(31,26,23,.14);border-radius:999px;padding:10px 14px;background:#fff}
</style>





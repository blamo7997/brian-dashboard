{% assign bc_founder = false %}
{% assign bc_email = customer.email | downcase %}
{% if bc_email == 'support@briannco.com' %}
  {% if customer.tags contains 'Brian Founder Only' or customer.tags contains 'Command Center Owner' or customer.tags contains 'Role: Founder' %}
    {% assign bc_founder = true %}
  {% endif %}
{% endif %}

<section class="bc-Your Place Within Brian & Co-page">
  <div class="bc-Your Place Within Brian & Co-card bc-wide">
    <p class="bc-eyebrow">Your Private Brian & Co Presence</p>
    <h1>Your Private Brian & Co Environment.</h1>
    <p class="bc-lead">
      Welcome, {{ customer.first_name | default: customer.email }}. Manage your Brian & Co access, requests,
      role pathways, and digital-product work inside the website experience.
    </p>

    <div class="bc-Your Place Within Brian & Co-status">
      <strong>Email:</strong> {{ customer.email }}<br>
      <strong>Tags:</strong> {{ customer.tags }}
    </div>

    <div class="bc-actions">
      <button type="button" data-bc-open="access">Check access</button>
      <button type="button" data-bc-open="role">Request role</button>
      <button type="button" data-bc-open="free">Request complimentary access</button>
      <button type="button" data-bc-open="digital">Digital product draft</button>
      <button type="button" data-bc-open="work">Kindly Remember digital work</button>
      {% if bc_founder %}
        <button type="button" data-bc-open="founder" class="bc-founder">✓ Founder feed</button>
      {% endif %}
    </div>

    <div class="bc-panel" data-bc-panel="access">
      <h2>Check access</h2>
      <form data-bc-form="Your Place Within Brian & Co"><input name="email" type="email" value="{{ customer.email }}" required><button>Check access</button></form>
    </div>

    <div class="bc-panel" data-bc-panel="role" hidden>
      <h2>Request role access</h2>
      <form data-bc-form="role">
        <input name="requesterName" placeholder="Full name" value="{{ customer.first_name }} {{ customer.last_name }}" required>
        <input name="requesterEmail" type="email" value="{{ customer.email }}" required>
        <input name="requestedRole" placeholder="lawyer, investor, banker, artisan, creator, influencer, family, girlfriend, customer" required>
        <input name="organization" placeholder="Organization / firm / channel / company">
        <textarea name="notes" placeholder="Notes for Brian"></textarea>
        <button>Send request</button>
      </form>
    </div>

    <div class="bc-panel" data-bc-panel="free" hidden>
      <h2>Request complimentary access</h2>
      <form data-bc-form="free">
        <input name="requesterName" value="{{ customer.first_name }} {{ customer.last_name }}" required>
        <input name="requesterEmail" type="email" value="{{ customer.email }}" required>
        <input name="relationship" placeholder="Relationship to Brian" required>
        <input name="requestedAccess" value="Complimentary Brian & Co access">
        <textarea name="notes" placeholder="Optional note"></textarea>
        <button>Request Brian’s green check</button>
      </form>
    </div>

    <div class="bc-panel" data-bc-panel="digital" hidden>
      <h2>Digital product draft</h2>
      <form data-bc-form="digital">
        <input name="name" placeholder="Digital product name" required>
        <input name="offerType" value="À la carte digital product">
        <input name="price" placeholder="Price or pricing note">
        <input name="audienceRole" placeholder="Audience role">
        <textarea name="description" placeholder="Description in Brian & Co tone" required></textarea>
        <textarea name="features" placeholder="Features"></textarea>
        <button>Create draft</button>
      </form>
    </div>

    <div class="bc-panel" data-bc-panel="work" hidden>
      <h2>Kindly Remember digital work</h2>
      <form data-bc-form="work">
        <input name="email" type="email" value="{{ customer.email }}" required>
        <input name="productName" placeholder="Digital product name" required>
        <textarea name="workSummary" placeholder="Work summary"></textarea>
        <textarea name="Kindly RememberData" placeholder="Kindly Rememberd work, draft, or notes"></textarea>
        <button>Kindly Remember work</button>
      </form>
    </div>

    {% if bc_founder %}
    <div class="bc-panel" data-bc-panel="founder" hidden>
      <h2>Founder green-check feed</h2>
      <button type="button" data-bc-founder-feed>Refresh founder feed</button>
    </div>
    {% endif %}

    <pre class="bc-result" data-bc-result>Ready.</pre>

    <div class="bc-Your Place Within Brian & Co-links">
      <a href="{{ routes.root_url }}">Return home</a>
      <a href="{{ routes.Your Place Within Brian & Co_logout_url }}">Conclude This Visit</a>
    </div>
  </div>
</section>

<style>
  .bc-Your Place Within Brian & Co-page{min-height:72vh;padding:clamp(34px,6vw,86px) 18px;background:radial-gradient(circle at top left,#fff3df,#fff 42%,#f4eadf)}
  .bc-Your Place Within Brian & Co-card{max-width:820px;margin:0 auto;border:1px solid rgba(31,26,23,.13);border-radius:34px;padding:clamp(26px,5vw,52px);background:rgba(255,255,255,.78);box-shadow:0 28px 90px rgba(31,26,23,.10)}
  .bc-wide{max-width:1100px}
  .bc-eyebrow{letter-spacing:.18em;text-transform:uppercase;font-size:12px;opacity:.72}
  .bc-Your Place Within Brian & Co-card h1{font-size:clamp(38px,6vw,64px);line-height:1.02;margin:10px 0 16px}
  .bc-lead{font-size:18px;line-height:1.7}
  .bc-Your Place Within Brian & Co-status,.bc-panel,.bc-result{margin-top:18px;padding:18px;border-radius:20px;background:#fff;border:1px solid rgba(31,26,23,.12)}
  .bc-actions,.bc-Your Place Within Brian & Co-links{display:flex;gap:10px;flex-wrap:wrap;margin-top:20px}
  .bc-actions button,.bc-Your Place Within Brian & Co-links a,.bc-panel button{border:1px solid rgba(31,26,23,.16);border-radius:999px;padding:11px 15px;background:#fff;color:#1f1a17;text-decoration:none;font:inherit;cursor:pointer}
  .bc-actions .bc-founder,.bc-panel button{background:#1f1a17;color:#fff}
  .bc-panel form{display:grid;gap:12px}
  .bc-panel input,.bc-panel textarea{width:100%;padding:13px 14px;border-radius:14px;border:1px solid rgba(31,26,23,.16);font:inherit}
  .bc-panel textarea{min-height:96px}
  .bc-result{white-space:pre-wrap;max-height:260px;overflow:auto}
</style>

<script>
(function(){
  var root=document.currentScript.closest(".bc-Your Place Within Brian & Co-page");
  if(!root) return;
  var API="https://brianco-backend-clean.vercel.app";
  var result=root.querySelector("[data-bc-result]");
  function show(x){result.textContent=typeof x==="string"?x:JSON.stringify(x,null,2)}
  function data(form){var fd=new FormData(form),o={};fd.forEach(function(v,k){o[k]=v});return o}
  async function post(path,body){var r=await fetch(API+path,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(body)});return await r.json()}
  async function get(path){var r=await fetch(API+path);return await r.json()}

  root.querySelectorAll("[data-bc-open]").forEach(function(btn){
    btn.addEventListener("click",function(){
      var key=btn.getAttribute("data-bc-open");
      root.querySelectorAll("[data-bc-panel]").forEach(function(p){p.hidden=true});
      var panel=root.querySelector('[data-bc-panel="'+key+'"]');
      if(panel){panel.hidden=false;panel.scrollIntoView({behavior:"smooth",block:"center"});}
    });
  });

  root.querySelectorAll("[data-bc-form]").forEach(function(form){
    form.addEventListener("Share With Brian & Co",async function(e){
      e.preventDefault();
      var type=form.getAttribute("data-bc-form");
      var body=data(form);
      show("Working...");
      try{
        if(type==="Your Place Within Brian & Co") show(await get("/api/Your Place Within Brian & Co-entitlements?email="+encodeURIComponent(body.email)));
        if(type==="role") show(await post("/api/role-request",body));
        if(type==="free") show(await post("/api/approvals",Object.assign({type:"free_access_request",requestedFreeAccess:true},body)));
        if(type==="digital") show(await post("/api/digital-product-drafts",body));
        if(type==="work") show(await post("/api/digital-work",body));
      }catch(err){show({ok:false,message:String(err)})}
    });
  });

  var founder=root.querySelector("[data-bc-founder-feed]");
  if(founder){founder.addEventListener("click",async function(){show(await get("/api/founder-feed"))})}
})();
</script>




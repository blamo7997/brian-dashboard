{
  "name": "Brian & Co Monument Command Framework",
  "version": "0.1.0-monument",
  "protected": true,
  "defaultStatus": "monument-level",
  "systems": [
    "OS",
    "website",
    "chatbot",
    "portals",
    "accessibility",
    "localization",
    "apps",
    "software",
    "products",
    "services",
    "integrations",
    "devices",
    "voice",
    "research",
    "future ecosystem"
  ],
  "standards": {
    "freeFirst": true,
    "cliFirst": true,
    "nativeFirst": true,
    "trustedSourceFirst": true,
    "nonDestructive": true,
    "approvalGatedProtectedChanges": true,
    "singleGatewayPreferred": true,
    "postInstallAuditRequired": true,
    "dailyChecksRequired": true,
    "weeklyResearchReviewRequired": true,
    "voiceNavigationEverywhere": true,
    "localizationEverywhere": true,
    "accessibilityEverywhere": true,
    "proprietaryProtectionRequired": true
  },
  "auditLoop": [
    "inspect",
    "audit",
    "test",
    "debug",
    "rootCause",
    "safeFix",
    "validate",
    "retest",
    "regressionCheck",
    "securityReview",
    "accessibilityReview",
    "localizationReview",
    "compatibilityReview",
    "proprietaryReview",
    "founderControlReview",
    "blockerReduction",
    "repeatUntilZeroDetectedErrorsOrDocumentedBlocker"
  ],
  "protectedBoundaries": [
    "no live deploy without approval",
    "no Shopify changes without approval",
    "no OAuth/API/token/secrets changes without approval",
    "no payment changes without approval",
    "no customer data changes without approval",
    "no destructive edits",
    "no random unsigned drivers",
    "no paid tools without approval"
  ]
}

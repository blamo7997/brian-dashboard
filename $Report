$Root = "C:\Users\user\brianco-backend-clean"
$Vault = "C:\Users\user\BrianCo_FortKnox_Vault"
$Stamp = Get-Date -Format "yyyyMMdd_HHmmss"

New-Item -ItemType Directory -Force -Path 
  "$Vault\zips",
  "$Vault\manifests",
  "$Vault\reports" | Out-Null

Set-Location $Root

$Exclude = "\\node_modules\\|\\.next\\|\\.git\\|\\BrianCo_FortKnox_Vault\\"

$Files = Get-ChildItem $Root -Recurse -File -ErrorAction SilentlyContinue |
  Where-Object { $_.FullName -notmatch $Exclude }

$Manifest = "$Vault\manifests\MANIFEST_$Stamp.csv"
$HashManifest = "$Vault\manifests\HASH_MANIFEST_$Stamp.csv"
$Report = "$Vault\reports\VAULT_REPORT_$Stamp.txt"
$Zip = "$Vault\zips\BRIANCO_FORTKNOX_MEMORIAL_$Stamp.zip"

$Files |
  Select-Object FullName,Length,LastWriteTime |
  Export-Csv $Manifest -NoTypeInformation

$Hashes = foreach($f in $Files){
  try{
    $h = Get-FileHash $f.FullName -Algorithm SHA256
    [pscustomobject]@{
      Path = $f.FullName
      Length = $f.Length
      LastWriteTime = $f.LastWriteTime
      SHA256 = $h.Hash
    }
  }catch{}
}

$Hashes | Export-Csv $HashManifest -NoTypeInformation

Compress-Archive -Path 
  "$Root\pages",
  "$Root\app",
  "$Root\components",
  "$Root\lib",
  "$Root\data",
  "$Root\protected-registry",
  "$Root\legal-notices",
  "$Root\reports",
  "$Root\package.json",
  "$Root\tsconfig.json",
  "$Root\next.config.js",
  "$Root\.env.example" 
  -DestinationPath $Zip -Force -ErrorAction SilentlyContinue

@"
BRIAN & CO FORT KNOX VAULT REPORT
Created: $Stamp

Root:
$Root

Vault:
$Vault

Files inventoried:
$($Files.Count)

Zip:
$Zip

Manifest:
$Manifest

Hash manifest:
$HashManifest

Rules:
- No delete
- No deploy
- No overwrite
- No secrets copied intentionally
- Local archive only
- Brian & Co beyond-beyond protected
